{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["opencode", "opencode-go", "github"],
  "model": "opencode/claude-sonnet-4-5",
  "small_model": "opencode/claude-haiku-4-5",
  "plugin": ["opencode-mem"],
  "instructions": ["AGENTS.md", "docs/guidelines.md", ".cursor/rules/*.md"],
  "compaction": { "auto": true, "prune": true, "reserved": 15000 },
  "watcher": { "ignore": ["node_modules/**", "dist/**", ".git/**", "*.log"] },
  "snapshot": true,
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "description": "Coordinates subagents for complex tasks",
      "model": "opencode/claude-sonnet-4-5",
      "permission": {
        "task": { "*": "ask", "reviewer": "allow", "explorer": "allow" }
      }
    },
    "reviewer": {
      "mode": "subagent",
      "description": "Security and performance review, read-only",
      "model": "opencode/claude-haiku-4-5",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "ask"
      }
    }
  },
  "permission": {
    "bash": "ask",
    "edit": "ask"
  }
}
